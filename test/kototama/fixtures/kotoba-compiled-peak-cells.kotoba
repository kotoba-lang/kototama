(defn max1 [x]
  (if (< x 1) 1 x))
(defn tree-height [s b]
  (let [s1 (max1 s)]
    (let [b1 (max1 b)]
      (/ (+ s1 (- b1 1)) b1))))
(defn isqrt-iter [n x prev]
  (let [x2 (/ (+ x (/ n x)) 2)]
    (if (= x2 x)
      x
      (if (= x2 prev)
        (if (< (* x2 x2) n) x2 x)
        (isqrt-iter n x2 x)))))
(defn isqrt [n]
  (if (< n 1)
    0
    (if (< n 4)
      1
      (isqrt-iter n (/ n 2) 0))))
(defn ilog2-iter [n acc]
  (if (< n 2)
    acc
    (ilog2-iter (/ n 2) (+ acc 1))))
(defn ilog2 [n]
  (if (< n 1)
    0
    (ilog2-iter n 0)))
(defn optimal-block-proxy [s]
  (let [s1 (max1 s)]
    (let [lg (max1 (ilog2 s1))]
      (let [raw (isqrt (* s1 lg))]
        (max1 raw)))))
(defn main []
  (let [s 4096]
    (let [b (optimal-block-proxy s)]
      (let [h (tree-height s b)]
        (+ h b)))))
