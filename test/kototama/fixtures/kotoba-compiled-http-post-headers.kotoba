;; kotoba-compiled-http-post-headers.kotoba -- com-junkawasaki/root, third
;; wave (kototama actor:host ABI, http_post_headers). Same "prove real
;; compiler-to-tender LINKAGE via SSRF-guard EXECUTION, not a live network
;; round trip" pattern kotoba-compiled-http-fetch.kotoba already
;; established -- the URL is deliberately loopback, so kototama's
;; unconditional denylist refuses it (-1) before any real connection is
;; attempted.
(ns demo-actor-host-http-post-headers)

(defn main []
  (http-post-headers (str-ptr "http://127.0.0.1/") (str-len "http://127.0.0.1/")
                      (str-ptr "body") (str-len "body")
                      (str-ptr "Authorization\tBearer tok") (str-len "Authorization\tBearer tok")
                      (alloc 64) 64))
