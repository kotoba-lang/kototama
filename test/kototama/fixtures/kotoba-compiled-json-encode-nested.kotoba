;; kotoba-compiled-json-encode-nested.kotoba -- com-junkawasaki/root, third
;; wave (kototama actor:host ABI, json_encode's dotted-path nesting
;; extension). Same host-import (json_encode), same ABI shape as
;; kotoba-compiled-json-encode.kotoba -- the pairs text mixes an object
;; ("s.t"/"s.s") and an array ("p.resources.0"/"p.resources.1"), the same
;; two nesting shapes com.atproto.repo.createRecord's real request body
;; needs (record.cites.N.url) and CACAO's own wire envelope needs
;; (p.resources.N).
(ns demo-actor-host-json-encode-nested)

(defn main []
  (json-encode (str-ptr "s.t\teip4361\ns.s\tsigvalue\np.resources.0\ta\np.resources.1\tb")
               (str-len "s.t\teip4361\ns.s\tsigvalue\np.resources.0\ta\np.resources.1\tb")
               (alloc 128) 128))
