;; kotoba-compiled-cbor-encode-nested.kotoba -- com-junkawasaki/root, third
;; wave (kototama actor:host ABI, cbor_encode's dotted-path nesting
;; extension). Same host-import (cbor_encode), same ABI shape as
;; kotoba-compiled-cbor-encode.kotoba -- only the pairs text uses a
;; dotted key ("s.t"/"s.s"), exactly the CACAO wire's own nested "s"
;; object shape ({"t":"eip4361","s":"eip4361"}'s sibling under CACAO's
;; real {"h":{...},"p":{...},"s":{...}} envelope).
(ns demo-actor-host-cbor-encode-nested)

(defn main []
  (cbor-encode (str-ptr "s.t\teip4361\ns.s\tsigvalue") (str-len "s.t\teip4361\ns.s\tsigvalue")
               (alloc 128) 128))
