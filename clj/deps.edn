{;; the common organism/cell library lives in ../lib (lib/kototama/*.cljc, the
 ;; runtime's portable lib); this clj subtree adds the UNSPSC fleet on top.
 :paths ["src" "resources" "../lib"]
 ;; UNSPSC organism actors on the Clojure substrate:
 ;;   langgraph  — StateGraph orchestration (the agent graph)
 ;;   langchain  — model adapter (Murakumo), Datomic-shaped EAV + kotoba_db backend
 ;; Workspace-local roots. This clj subtree lives at orgs/kotoba-lang/kototama/clj;
 ;; the clj libs are siblings of kototama under orgs/kotoba-lang/ (../../<lib>).
 ;; The langchain :local/root overrides langgraph's transitive git dep so the
 ;; whole stack resolves offline against the local checkouts.
 :deps {io.github.kotoba-lang/langgraph {:local/root "../../langgraph"}
        io.github.kotoba-lang/langchain {:local/root "../../langchain"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; taxonomy EDN builder (bb or clojure): joins the UNSPSC registry + enrichment
  :build-taxonomy {:extra-deps {org.clojure/data.json {:mvn/version "2.5.0"}}
                   :main-opts ["-m" "kototama.unspsc.build-taxonomy"]}
  ;; Phase 2 enrichment: dump codes needing spec, merge generated overlays
  :enrich {:extra-deps {org.clojure/data.json {:mvn/version "2.5.0"}}
           :main-opts ["-m" "kototama.unspsc.enrich"]}
  ;; Phase 3: full-fleet sweep on one kotoba-Datom log
  :fleet {:main-opts ["-m" "kototama.unspsc.fleet"]}}}
