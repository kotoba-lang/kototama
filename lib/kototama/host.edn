;; actor:host ABI — the capability boundary for atproto actors + artificial organisms,
;; analogous to the `kami:engine` ABI for games. The PURE actor logic (kototama.gates /
;; kototama.membrane / kototama.heartbeat / kototama.didkey) compiles to wasm under ACTOR_PRELUDE;
;; anything that touches platform crypto, the network, the clock, or storage is a HOST
;; import the runtime provides (native bb/JVM host today; a wasm host over these imports
;; next). The actor is the BEARER of capability, never the holder of a server key
;; (no-server-key, ADR-2605231525): the host signs present-only with the actor's OWN sealed
;; did:key and never exfiltrates the seed.
[{:db/id -1, :abi/namespace "actor:host", :abi/version 0, :abi/imports "[{:fn \"gen-keypair\", :sig \"() -> {:did did:key :public bytes32 :private opaque}\", :note \"self-generate an Ed25519 keypair IN the actor; seed sealed by the host, never returned to logged callers\"} {:fn \"sign\", :sig \"(priv, msg-bytes) -> sig-bytes\", :note \"present-only: the sealed key signs; it is used, never exfiltrated\"} {:fn \"verify\", :sig \"(pub32, msg-bytes, sig-bytes) -> bool\", :note \"pure verify against a public did:key (no secret needed)\"} {:fn \"sha256-hex\", :sig \"(bytes) -> hex-string\", :note \"the hash under tx-cid / verify-chain (kotoba commit-DAG)\"} {:fn \"http-post\", :sig \"(url, json-body, headers) -> {:status :body}\", :note \"host allowlist enforced (loopback + fleet LAN); read-only public fetch needs no key/operator\"} {:fn \"log-read\", :sig \"(log-path) -> [tx …]\", :note \"read the commit-DAG\"} {:fn \"log-append!\", :sig \"(tx, log-path) -> head-cid\", :note \"append one tx (host hashes + chains)\"} {:fn \"now\", :sig \"() -> epoch-int\", :note \"host clock; pure logic takes as-of as an arg\"}]", :abi/notes ["The pure layers NEVER call these directly in a way that hides I/O — they DECIDE; the host ACTS." "Outward broadcast (AT-proto :published) is a §1.12 Council gate ON TOP of this ABI, not a host fn." "Mirrors kami:engine: games get vec/map/timer + draw via the engine ABI; actors get crypto/net/storage via actor:host."]}]
