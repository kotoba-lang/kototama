{:paths ["src" "test" "lib"]
 ;; kototama.tender (the "tender" ADR-2607022400/2607022900 decided on:
 ;; JVM/Clojure via Chicory, not Rust/wasmtime) is the only namespace here
 ;; needing real deps -- kototama.contract and lib/* stay zero-dep/portable.
 :deps {com.dylibso.chicory/wasm     {:mvn/version "1.4.0"}  ; same pin as kotoba-lang/kotoba
        com.dylibso.chicory/runtime {:mvn/version "1.4.0"}
        io.github.kotoba-lang/ed25519
        {:git/url "https://github.com/kotoba-lang/ed25519.git"
         :git/sha "fdcefb9f1b83461fee54d04b63e374fa301ee847"}
        ;; llm-infer-host-fn's Anthropic Messages API request/response
        ;; bodies -- same lib+version kototama-clj's :build-taxonomy/
        ;; :enrich aliases already pin elsewhere in this org.
        org.clojure/data.json {:mvn/version "2.5.0"}
        ;; kototama.aiueos-adapter calls aiueos.cli/command-result directly
        ;; (in-process, not the bb-decide subprocess -- see the adapter's
        ;; namespace docstring for why) to translate a REAL aiueos policy
        ;; decision into a kototama.contract/host-caps value. aiueos-cljc-
        ;; contract (a short-lived split of aiueos.cli/etc. into its own
        ;; repo) has been merged back into kotoba-lang/aiueos.
        io.github.kotoba-lang/aiueos
        {:git/url "https://github.com/kotoba-lang/aiueos.git"
         :git/sha "63c13fd48dc53e0f93fa40f6bfce54e62773c656"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
       ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
       :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
