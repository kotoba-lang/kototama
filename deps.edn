{:paths ["src" "test" "lib"]
 ;; kototama.tender (ADR-2607022400 names the "tender" ROLE; ADR-2607022900
 ;; separately decided THIS implementation of that role is JVM/Clojure via
 ;; Chicory, not Rust/wasmtime -- other tenders in other host languages
 ;; exist, e.g. aiueos's own JVM-FFM ADR-0014 hvt-tender) is the only
 ;; namespace here needing real deps -- kototama.contract and lib/* stay
 ;; zero-dep/portable.
 :deps {com.dylibso.chicory/wasm     {:mvn/version "1.4.0"}  ; same pin as kotoba-lang/kotoba
        com.dylibso.chicory/runtime {:mvn/version "1.4.0"}
        io.github.kotoba-lang/ed25519
        {:git/url "https://github.com/kotoba-lang/ed25519.git"
         :git/sha "fdcefb9f1b83461fee54d04b63e374fa301ee847"}
        ;; llm-infer-host-fn's Anthropic Messages API request/response
        ;; bodies -- same lib+version kototama-clj's :build-taxonomy/
        ;; :enrich aliases already pin elsewhere in this org.
        org.clojure/data.json {:mvn/version "2.5.0"}
        io.github.kotoba-lang/security {:git/url "https://github.com/kotoba-lang/security.git"
                                        :git/sha "4f9847e15219b2e97ea4cdad325357bd7f85c21d"}
        ;; kototama.aiueos-adapter calls aiueos.cli/command-result directly
        ;; (in-process, not the bb-decide subprocess -- see the adapter's
        ;; namespace docstring for why) to translate a REAL aiueos policy
        ;; decision into a kototama.contract/host-caps value. aiueos-cljc-
        ;; contract (a short-lived split of aiueos.cli/etc. into its own
        ;; repo) has been merged back into kotoba-lang/aiueos.
        io.github.kotoba-lang/aiueos
        {:git/url "https://github.com/kotoba-lang/aiueos.git"
         :git/sha "63c13fd48dc53e0f93fa40f6bfce54e62773c656"}}
 :aliases
 {:cli  {:main-opts ["-m" "kototama.cli"]}
  :postgresql-interop
  {:extra-deps {io.github.kotoba-lang/kotoba {:local/root "../kotoba"}
                io.github.kotoba-lang/compiler {:local/root "../compiler"}
                io.github.kotoba-lang/kotoba-core-contracts
                {:local/root "../kotoba-core-contracts"}
                io.github.kotoba-lang/kotoba-lang {:local/root "../kotoba-lang"}}
   :main-opts ["-m" "kototama.postgresql-interop"]}
  :doctor {:main-opts ["-m" "kototama.cli" "doctor"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                      io.github.kotoba-lang/kotoba
                      {:local/root "../kotoba"}
                      io.github.kotoba-lang/compiler
                      {:local/root "../compiler"}
                      io.github.kotoba-lang/kotoba-core-contracts
                      {:local/root "../kotoba-core-contracts"}
                      io.github.kotoba-lang/kotoba-lang
                      {:local/root "../kotoba-lang"}}
         ;; A sibling kotoba checkout may itself pin an unpublished
         ;; kotoba-lang commit.  extra-deps does not reliably win that
         ;; transitive coordinate; the workspace test profile must.
         :override-deps {io.github.kotoba-lang/kotoba-lang
                         {:local/root "../kotoba-lang"}
                         io.github.kotoba-lang/kotoba-core-contracts
                         {:local/root "../kotoba-core-contracts"}
                         io.github.kotoba-lang/kotoba-selfhost-contracts
                         {:local/root "../kotoba-selfhost-contracts"}
                         io.github.kotoba-lang/org-chainagnostic-cacao
                         {:local/root "../org-chainagnostic-cacao"}
                         io.github.kotoba-lang/datom
                         {:local/root "../datom"}
                         io.github.kotoba-lang/org-w3-did
                         {:local/root "../org-w3-did"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
       ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
       :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
